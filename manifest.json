{
  "manifest_version": 3,
  "name": "Watch End Time",
  "short_name": "Watch End Time",
  "description": "Affiche l'heure estimée de fin dans les contrôles des lecteurs YouTube, Netflix, Prime Video, Disney+, Vimeo, Dailymotion et Twitch.",
  "version": "0.6.0",
  "author": "3Devs",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Watch End Time",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://www.netflix.com/*",
        "https://*.netflix.com/*",
        "https://www.primevideo.com/*",
        "https://*.primevideo.com/*",
        "https://www.amazon.com/*",
        "https://www.amazon.co.uk/*",
        "https://www.amazon.de/*",
        "https://www.amazon.fr/*",
        "https://www.amazon.it/*",
        "https://www.amazon.es/*",
        "https://www.amazon.ca/*",
        "https://www.amazon.co.jp/*",
        "https://www.amazon.com.au/*",
        "https://www.amazon.in/*",
        "https://www.disneyplus.com/*",
        "https://*.disneyplus.com/*",
        "https://*.bamgrid.com/*",
        "https://*.disney-plus.net/*",
        "https://vimeo.com/*",
        "https://*.vimeo.com/*",
        "https://www.dailymotion.com/*",
        "https://*.dailymotion.com/*",
        "https://dai.ly/*",
        "https://www.twitch.tv/*",
        "https://*.twitch.tv/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
